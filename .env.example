# ============================================================
# Finance Dashboard — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Database -----------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/finance_dashboard"

# --- Crypto: Trezor watch-only addresses --------------------------------
# Set your real public addresses to get live on-chain balances.
# READ-ONLY. No private keys or seeds ever go here.
#
# BTC: native SegWit (bc1q...), legacy (1...), or P2SH (3...) address.
# xpub scanning is not yet implemented — use the first receiving address.
BTC_ADDRESS=

# ETH: standard 0x... address
ETH_ADDRESS=

# Ethplorer API key — 'freekey' works for low volume (<100 req/min).
# Upgrade at https://ethplorer.io/wallet#createKey for higher limits.
ETHPLORER_API_KEY=freekey

# --- Currency conversion ------------------------------------------------
# ILS to USD rate used when calculating net worth.
# Override if the default (0.27) drifts from the real rate.
ILS_USD_RATE=0.27

# --- Market data --------------------------------------------------------
# Yahoo Finance (stocks) and CoinGecko (crypto) are used for free.
# Alpha Vantage is an optional fallback if Yahoo Finance is unavailable.
ALPHA_VANTAGE_API_KEY=

# --- Authentication -------------------------------------------------------
# Protect the dashboard with a password. Leave blank to disable the gate.
DASHBOARD_PASSWORD=

# --- Feature flags -------------------------------------------------------
# Force mock data globally (useful for UI work without a DB or APIs).
FORCE_MOCK_DATA=false

# --- AI Insights ---------------------------------------------------------
# Required for the /api/ai-insights endpoint (portfolio analysis via Claude).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Email reminders (Resend) -------------------------------------------
# Required for the /api/reminders email notification feature.
# Get a free key at https://resend.com
RESEND_API_KEY=
# Address that reminders are sent FROM (must be a verified Resend sender)
REMINDER_EMAIL_FROM=noreply@yourdomain.com
# Address that reminders are sent TO (your personal email)
REMINDER_EMAIL_TO=you@yourdomain.com

# --- WhatsApp reminders (Twilio) ----------------------------------------
# Required for the /api/reminders WhatsApp notification feature.
# Sign up at https://twilio.com — sandbox is free for testing.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio WhatsApp sender in the format: whatsapp:+14155238886 (sandbox number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your WhatsApp number to receive reminders: whatsapp:+972501234567
REMINDER_WHATSAPP_TO=whatsapp:+your_number

# --- Webhooks & scheduled jobs ------------------------------------------
# Secret token used to authenticate inbound webhook requests (e.g. email webhooks).
# Generate with: openssl rand -hex 32
EMAIL_WEBHOOK_SECRET=
# Secret token for protecting cron job endpoints from unauthorised triggers.
# Generate with: openssl rand -hex 32
CRON_SECRET=
# Public URL of your deployed app — used to build absolute webhook callback URLs.
# Example: https://findash.yourdomain.com  (no trailing slash)
APP_URL=http://localhost:3000
